# Copy this file to .env. The .env file is ignored by Git.
# Never place a real credential in this example file.

# OpenAI-compatible vLLM endpoint used by the reground adapter.
VLM_EVAL_ROOT=./third_party/VLMEvalKit
REGROUND_BASE_URL=http://localhost:8011/v1
REGROUND_MODEL_NAME=qwen2_5-vl-reground
REGROUND_API_KEY=EMPTY
REGROUND_LOG_DIR=./token_logs

# Evaluation defaults. exact_matching needs no external judge credential.
REGROUND_DATASET=HallusionBench
REGROUND_JUDGE=exact_matching
REGROUND_API_WORKERS=32
REGROUND_OUTPUT_DIR=./outputs
# REGROUND_PYTHON=/absolute/path/to/python

# Optional local server settings.
# QWEN_MODEL_PATH=/path/to/qwen-checkpoint
VLLM_PORT=8011
TENSOR_PARALLEL_SIZE=1

# Only add external judge variables to your private .env if you deliberately
# select REGROUND_JUDGE=gpt4o. Do not add them to this tracked template.
